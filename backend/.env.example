# Vinsla AI Academy — Environment Variables
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here

# Database
DATABASE_URL=postgresql://vinsla:vinsla123@localhost:5432/vinsla_academy

# Email
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@vinslaacademy.com

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Storage
UPLOAD_FOLDER=/tmp/vinsla_uploads
CERTIFICATE_FOLDER=/tmp/vinsla_certificates

# App
APP_URL=http://localhost:5000
